ninja_required_version = 1.3
cxx = c++
nvcc = /usr/local/cuda/bin/nvcc

cflags = -pthread -B /root/software/miniconda3/compiler_compat -Wno-unused-result -Wsign-compare -DNDEBUG -O2 -Wall -fPIC -O2 -isystem /root/software/miniconda3/include -I/root/software/miniconda3/include -fPIC -O2 -isystem /root/software/miniconda3/include -fPIC -DWITH_CUDA -I/root/software/miniconda3/lib/python3.9/site-packages/torch/include -I/root/software/miniconda3/lib/python3.9/site-packages/torch/include/torch/csrc/api/include -I/usr/local/cuda/include -I/root/software/miniconda3/include/python3.9 -c
post_cflags = -DTORCH_API_INCLUDE_EXTENSION_H '-DPYBIND11_COMPILER_TYPE="_gcc"' '-DPYBIND11_STDLIB="_libstdcpp"' '-DPYBIND11_BUILD_ABI="_cxxabi1018"' -DTORCH_EXTENSION_NAME=iou3d_op -std=c++17
cuda_cflags = -DWITH_CUDA -I/root/software/miniconda3/lib/python3.9/site-packages/torch/include -I/root/software/miniconda3/lib/python3.9/site-packages/torch/include/torch/csrc/api/include -I/usr/local/cuda/include -I/root/software/miniconda3/include/python3.9 -c
cuda_post_cflags = -D__CUDA_NO_HALF_OPERATORS__ -D__CUDA_NO_HALF_CONVERSIONS__ -D__CUDA_NO_BFLOAT16_CONVERSIONS__ -D__CUDA_NO_HALF2_OPERATORS__ --expt-relaxed-constexpr --compiler-options ''"'"'-fPIC'"'"'' -DTORCH_API_INCLUDE_EXTENSION_H '-DPYBIND11_COMPILER_TYPE="_gcc"' '-DPYBIND11_STDLIB="_libstdcpp"' '-DPYBIND11_BUILD_ABI="_cxxabi1018"' -DTORCH_EXTENSION_NAME=iou3d_op -gencode=arch=compute_86,code=compute_86 -gencode=arch=compute_86,code=sm_86 -std=c++17
cuda_dlink_post_cflags = 
sycl_dlink_post_cflags = 
ldflags = 

rule compile
  command = $cxx -MMD -MF $out.d $cflags -c $in -o $out $post_cflags
  depfile = $out.d
  deps = gcc

rule cuda_compile
  depfile = $out.d
  deps = gcc
  command = $nvcc --generate-dependencies-with-compile --dependency-output $out.d $cuda_cflags -c $in -o $out $cuda_post_cflags







build /mnt/nfs_docker_volume/training-container-space/code/PointPillars/ops/build/temp.linux-x86_64-3.9/iou3d/iou3d.o: compile /mnt/nfs_docker_volume/training-container-space/code/PointPillars/ops/iou3d/iou3d.cpp
build /mnt/nfs_docker_volume/training-container-space/code/PointPillars/ops/build/temp.linux-x86_64-3.9/iou3d/iou3d_kernel.o: cuda_compile /mnt/nfs_docker_volume/training-container-space/code/PointPillars/ops/iou3d/iou3d_kernel.cu








